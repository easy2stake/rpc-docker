# Before running:
# cp env.template .env
# Edit values as needed, then: docker compose up -d

# Data directory (persistent node data)
# Use full path, e.g. /home/user/hl-data
# HL_DATA_DIR=/home/user/hl-data

# RPC port (EVM + info server)
RPC_PORT=3001

# Pruner: retention in hours before deleting old data (default: 48)
PRUNE_RETENTION_HOURS=48
